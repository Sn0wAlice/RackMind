<div class="breadcrumb">
  <a href="/users">Users</a>
  <i class="fa-solid fa-chevron-right separator"></i>
  <span>Add User</span>
</div>

<div class="card fade-up" style="max-width:480px;">
  <div class="card-body">
    <form method="POST" action="/users/create">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required placeholder="Username" minlength="3">
      </div>

      <div class="form-group">
        <label for="email">Email (optional)</label>
        <input type="email" id="email" name="email" placeholder="user@example.com">
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="Minimum 6 characters" minlength="6">
      </div>

      <div class="form-check">
        <input type="checkbox" id="must_change_password" name="must_change_password" value="1">
        <label for="must_change_password">Force password change on first login</label>
      </div>

      <div class="btn-group">
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-plus"></i> Create User
        </button>
        <a href="/users" class="btn">Cancel</a>
      </div>
    </form>
  </div>
</div>
