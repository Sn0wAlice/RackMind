<div class="breadcrumb">
  <a href="/">Dashboard</a>
  <i class="fa-solid fa-chevron-right separator"></i>
  <a href="/items">Items</a>
  <i class="fa-solid fa-chevron-right separator"></i>
  <span>Print Labels</span>
</div>

<div class="section-header">
  <h3><%= items.length %> label<%= items.length !== 1 ? 's' : '' %></h3>
  <button class="btn btn-primary" onclick="window.print()"><i class="fa-solid fa-print"></i> Print</button>
</div>

<% if (items.length === 0) { %>
  <div class="card">
    <div class="empty-state fade-up">
      <i class="fa-solid fa-print"></i>
      <h3>No items to print</h3>
      <p>Apply filters on the items page first.</p>
    </div>
  </div>
<% } else { %>
  <div class="label-grid">
    <% items.forEach(function(item) { %>
      <div class="label-card fade-up">
        <h4><%= item.name %></h4>
        <p><%= item.type_name %> — <%= item.category_name %></p>
        <% if (item.location_name) { %><p><i class="fa-solid fa-location-dot"></i> <%= item.location_name %></p><% } %>
        <% if (item.serial_number) { %><p style="font-family:monospace;font-size:11px;"><%= item.serial_number %></p><% } %>
        <img src="/api/items/<%= item.id %>/qrcode" alt="QR" style="margin-top:8px;">
      </div>
    <% }); %>
  </div>
<% } %>
