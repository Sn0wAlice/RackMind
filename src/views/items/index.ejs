<div class="breadcrumb">
  <a href="/">Dashboard</a>
  <i class="fa-solid fa-chevron-right separator"></i>
  <span>Items</span>
</div>

<div class="section-header">
  <h3><%= total %> item<%= total !== 1 ? 's' : '' %></h3>
  <div class="btn-group">
    <a href="/items/labels?<%= new URLSearchParams(query).toString() %>" class="btn btn-sm" title="Print labels"><i class="fa-solid fa-print"></i> Labels</a>
    <a href="/items/create" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add Item</a>
  </div>
</div>

<div id="savedFilterPills" class="saved-filter-pills"></div>

<form method="GET" action="/items" class="filter-bar fade-up">
  <div class="filter-search">
    <i class="fa-solid fa-magnifying-glass"></i>
    <input type="text" name="search" placeholder="Search items..." value="<%= search %>">
  </div>
  <select name="category" onchange="this.form.submit()">
    <option value="">All Categories</option>
    <% categories.forEach(function(cat) { %>
      <option value="<%= cat.id %>" <%= filters.category == cat.id ? 'selected' : '' %>><%= cat.name %></option>
    <% }); %>
  </select>
  <% if (types.length > 0) { %>
    <select name="type" onchange="this.form.submit()">
      <option value="">All Types</option>
      <% types.forEach(function(t) { %>
        <option value="<%= t.id %>" <%= filters.type == t.id ? 'selected' : '' %>><%= t.name %></option>
      <% }); %>
    </select>
  <% } %>
  <select name="location" onchange="this.form.submit()">
    <option value="">All Locations</option>
    <% locations.forEach(function(loc) { %>
      <option value="<%= loc.id %>" <%= filters.location == loc.id ? 'selected' : '' %>><%= loc.path || loc.name %></option>
    <% }); %>
  </select>
  <select name="status" onchange="this.form.submit()">
    <option value="">All Statuses</option>
    <option value="in_stock" <%= filters.status === 'in_stock' ? 'selected' : '' %>>In Stock</option>
    <option value="in_use" <%= filters.status === 'in_use' ? 'selected' : '' %>>In Use</option>
    <option value="to_order" <%= filters.status === 'to_order' ? 'selected' : '' %>>To Order</option>
    <option value="broken" <%= filters.status === 'broken' ? 'selected' : '' %>>Broken</option>
  </select>
  <div class="view-toggle">
    <a href="?<%= new URLSearchParams({...query, view: 'card'}).toString() %>" class="<%= viewMode === 'card' ? 'active' : '' %>" title="Card view">
      <i class="fa-solid fa-grip"></i>
    </a>
    <a href="?<%= new URLSearchParams({...query, view: 'table'}).toString() %>" class="<%= viewMode === 'table' ? 'active' : '' %>" title="Table view">
      <i class="fa-solid fa-list"></i>
    </a>
  </div>
  <button type="button" class="btn btn-sm" id="saveFilterBtn" title="Save current filter"><i class="fa-solid fa-bookmark"></i></button>
  <noscript><button type="submit" class="btn btn-sm">Filter</button></noscript>
</form>

<!-- Bulk Actions Bar -->
<div class="bulk-bar" id="bulkBar">
  <span><span class="bulk-count" id="bulkCount">0</span> selected</span>
  <button class="btn bulk-status-btn" data-status="in_stock"><i class="fa-solid fa-circle-check"></i> In Stock</button>
  <button class="btn bulk-status-btn" data-status="in_use"><i class="fa-solid fa-circle-play"></i> In Use</button>
  <button class="btn bulk-status-btn" data-status="to_order"><i class="fa-solid fa-cart-shopping"></i> To Order</button>
  <button class="btn" id="bulkDeleteBtn" style="border-color:#f87171;color:#f87171;"><i class="fa-solid fa-trash"></i> Delete</button>
</div>

<% if (items.length === 0) { %>
  <div class="card">
    <div class="empty-state fade-up">
      <i class="fa-solid fa-box-open"></i>
      <h3>No items found</h3>
      <p><%= search ? 'Try a different search or clear filters.' : 'Start by adding your first item.' %></p>
      <% if (!search) { %>
        <a href="/items/create" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add Item</a>
      <% } %>
    </div>
  </div>
<% } else if (viewMode === 'table') { %>
  <div class="table-wrapper fade-up">
    <table>
      <thead>
        <tr>
          <th style="width:32px;"><input type="checkbox" class="bulk-check" id="selectAll"></th>
          <th>Name</th>
          <th>Type</th>
          <th>Category</th>
          <th>Location</th>
          <th>Status</th>
          <th>Qty</th>
          <th>Updated</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach(function(item) { %>
          <tr>
            <td><input type="checkbox" class="bulk-check" value="<%= item.id %>"></td>
            <td>
              <a href="/items/<%= item.id %>" class="item-name" style="display:inline-flex;align-items:center;">
                <% if (item.image_url) { %>
                  <img src="<%= item.image_url %>" alt="" class="table-thumb">
                <% } else { %>
                  <span class="table-item-icon"><i class="<%= item.type_icon %>"></i></span>
                <% } %>
                <%= item.name %>
              </a>
            </td>
            <td><span class="badge"><%= item.type_name %></span></td>
            <td><%= item.category_name %></td>
            <td><%= item.location_name || '—' %></td>
            <td>
              <% var s = item.status || 'in_stock'; var sIcon = s === 'in_stock' ? 'fa-circle-check' : s === 'in_use' ? 'fa-circle-play' : s === 'to_order' ? 'fa-cart-shopping' : 'fa-circle-xmark'; %>
              <span class="status-badge status-<%= s %>"><i class="fa-solid <%= sIcon %> status-icon"></i> <%= s.replace(/_/g, ' ') %></span>
            </td>
            <td>
              <% if (item.is_unique) { %>1<% } else { %>
                <div class="qty-controls">
                  <button class="qty-btn" data-item-id="<%= item.id %>" data-delta="-1">−</button>
                  <span class="qty-value"><%= item.quantity %></span>
                  <button class="qty-btn" data-item-id="<%= item.id %>" data-delta="1">+</button>
                </div>
              <% } %>
            </td>
            <td><%= new Date(item.updated_at).toLocaleDateString() %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="items-grid">
    <% items.forEach(function(item) { %>
      <div class="item-card card card-hover fade-up" style="position:relative;">
        <input type="checkbox" class="bulk-check" value="<%= item.id %>" style="position:absolute;top:12px;right:12px;z-index:2;">
        <a href="/items/<%= item.id %>" style="text-decoration:none;display:block;padding:18px;">
          <div class="item-card-header">
            <div class="item-card-icon">
              <% if (item.image_url) { %>
                <img src="<%= item.image_url %>" alt="" style="width:40px;height:40px;border-radius:10px;object-fit:cover;">
              <% } else { %>
                <i class="<%= item.type_icon %>"></i>
              <% } %>
            </div>
            <div class="item-card-info">
              <h4><%= item.name %></h4>
              <p><%= item.type_name %></p>
            </div>
            <% var s = item.status || 'in_stock'; var sIcon = s === 'in_stock' ? 'fa-circle-check' : s === 'in_use' ? 'fa-circle-play' : s === 'to_order' ? 'fa-cart-shopping' : 'fa-circle-xmark'; %>
            <span class="status-badge status-<%= s %>" style="margin-left:auto;font-size:10px;"><i class="fa-solid <%= sIcon %> status-icon"></i> <%= s.replace(/_/g, ' ') %></span>
          </div>
          <div class="item-card-meta">
            <span class="badge"><i class="<%= item.category_icon %>"></i> <%= item.category_name %></span>
            <% if (item.location_name) { %>
              <span class="badge"><i class="fa-solid fa-location-dot"></i> <%= item.location_name %></span>
            <% } %>
            <% if (!item.is_unique && item.quantity > 1) { %>
              <span class="badge"><i class="fa-solid fa-layer-group"></i> x<%= item.quantity %></span>
            <% } %>
            <% if (item.tags) { item.tags.split(',').forEach(function(tag) { %>
              <span class="badge" style="font-size:10px;"><i class="fa-solid fa-tag"></i> <%= tag.trim() %></span>
            <% }); } %>
          </div>
        </a>
      </div>
    <% }); %>
  </div>
<% } %>

<%- include('../partials/pagination', { totalPages, currentPage, query }) %>
