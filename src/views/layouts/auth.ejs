<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>RackMind</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
  <div class="auth-container">
    <div class="auth-card card fade-up">
      <div class="auth-logo">
        <i class="fa-solid fa-server"></i>
        <h1>RackMind</h1>
        <p class="auth-subtitle">Inventory Management</p>
      </div>

      <% if (flash.error && flash.error.length) { %>
        <div class="alert alert-error">
          <i class="fa-solid fa-circle-exclamation"></i>
          <span><%= flash.error[0] %></span>
        </div>
      <% } %>
      <% if (flash.success && flash.success.length) { %>
        <div class="alert alert-success">
          <i class="fa-solid fa-circle-check"></i>
          <span><%= flash.success[0] %></span>
        </div>
      <% } %>
      <% if (flash.info && flash.info.length) { %>
        <div class="alert alert-info">
          <i class="fa-solid fa-circle-info"></i>
          <span><%= flash.info[0] %></span>
        </div>
      <% } %>

      <%- body %>
    </div>
  </div>
  <script>
    (function() {
      var token = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
      if (!token) return;
      document.querySelectorAll('form[method="POST"], form[method="post"]').forEach(function(form) {
        if (!form.querySelector('input[name="_csrf"]')) {
          var input = document.createElement('input');
          input.type = 'hidden';
          input.name = '_csrf';
          input.value = token;
          form.appendChild(input);
        }
      });
    })();
  </script>
  <script src="/js/app.js"></script>
</body>
</html>
