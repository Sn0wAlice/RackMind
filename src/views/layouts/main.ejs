<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>RackMind</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Mobile header -->
  <header class="mobile-header">
    <button class="hamburger" id="sidebarToggle" aria-label="Toggle menu">
      <i class="fa-solid fa-bars"></i>
    </button>
    <span class="mobile-logo">RackMind</span>
    <button class="theme-toggle" id="themeToggleMobile" aria-label="Toggle theme">
      <i class="fa-solid fa-moon"></i>
    </button>
  </header>

  <div class="app-layout">
    <%- include('../partials/sidebar') %>

    <main class="main-content">
      <div class="top-bar">
        <div class="top-bar-left">
          <h2 class="page-title"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h2>
        </div>
        <div class="top-bar-right">
          <form action="/items" method="GET" class="search-form">
            <div class="search-input-wrapper">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input type="text" name="search" placeholder="Search items..." value="<%= typeof search !== 'undefined' ? search : '' %>">
            </div>
          </form>
          <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
            <i class="fa-solid fa-moon"></i>
          </button>
        </div>
      </div>

      <%- include('../partials/flash') %>

      <div class="content">
        <%- body %>
      </div>
    </main>
  </div>

  <!-- Overlay for mobile sidebar -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <script src="/js/app.js"></script>
</body>
</html>
