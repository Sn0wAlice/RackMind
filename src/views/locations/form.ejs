<div class="breadcrumb">
  <a href="/">Dashboard</a>
  <i class="fa-solid fa-chevron-right separator"></i>
  <a href="/locations">Locations</a>
  <i class="fa-solid fa-chevron-right separator"></i>
  <span><%= editing ? 'Edit' : 'Add' %> Location</span>
</div>

<div class="card fade-up" style="max-width:560px;">
  <div class="card-body">
    <form method="POST" action="/locations/<%= editing ? location.id + '/edit' : 'create' %>">
      <div class="form-group">
        <label for="parent_id">Parent Location</label>
        <select id="parent_id" name="parent_id">
          <option value="">None (root level)</option>
          <% locations.forEach(function(loc) { %>
            <option value="<%= loc.id %>"
              <%= (editing && location.parent_id == loc.id) || (!editing && parentId == loc.id) ? 'selected' : '' %>>
              <%= loc.path || loc.name %>
            </option>
          <% }); %>
        </select>
      </div>

      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="e.g. Shelf A3"
          value="<%= editing ? location.name : '' %>">
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" placeholder="Optional description"><%= editing && location.description ? location.description : '' %></textarea>
      </div>

      <%- include('../partials/icon-picker', { currentIcon: currentIcon }) %>

      <div class="btn-group">
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-<%= editing ? 'check' : 'plus' %>"></i>
          <%= editing ? 'Save Changes' : 'Create Location' %>
        </button>
        <a href="<%= editing ? '/locations/' + location.id : '/locations' %>" class="btn">Cancel</a>
      </div>
    </form>
  </div>
</div>
