<div class="breadcrumb">
  <a href="/categories">Categories</a>
  <i class="fa-solid fa-chevron-right separator"></i>
  <span><i class="<%= category.icon %>"></i> <%= category.name %></span>
  <i class="fa-solid fa-chevron-right separator"></i>
  <span><%= editing ? 'Edit' : 'Add' %> Type</span>
</div>

<div class="card fade-up" style="max-width:560px;">
  <div class="card-body">
    <form method="POST" action="<%= editing ? '/categories/types/' + type.id + '/edit' : '/categories/' + category.id + '/types/create' %>">
      <div class="form-group">
        <label for="name">Type Name</label>
        <input type="text" id="name" name="name" required placeholder="e.g. Arduino Nano"
          value="<%= editing ? type.name : '' %>">
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" placeholder="Optional description"><%= editing && type.description ? type.description : '' %></textarea>
      </div>

      <%- include('../partials/icon-picker', { currentIcon: currentIcon }) %>

      <div class="btn-group">
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-<%= editing ? 'check' : 'plus' %>"></i>
          <%= editing ? 'Save Changes' : 'Create Type' %>
        </button>
        <a href="/categories" class="btn">Cancel</a>
      </div>
    </form>
  </div>
</div>
