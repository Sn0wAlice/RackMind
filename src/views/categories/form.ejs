<div class="breadcrumb">
  <a href="/categories">Categories</a>
  <i class="fa-solid fa-chevron-right separator"></i>
  <span><%= editing ? 'Edit' : 'Add' %> Category</span>
</div>

<div class="card fade-up" style="max-width:560px;">
  <div class="card-body">
    <form method="POST" action="/categories/<%= editing ? category.id + '/edit' : 'create' %>">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Category name"
          value="<%= editing ? category.name : '' %>">
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" placeholder="Optional description"><%= editing && category.description ? category.description : '' %></textarea>
      </div>

      <%- include('../partials/icon-picker', { currentIcon: currentIcon }) %>

      <div class="btn-group">
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-<%= editing ? 'check' : 'plus' %>"></i>
          <%= editing ? 'Save Changes' : 'Create Category' %>
        </button>
        <a href="/categories" class="btn">Cancel</a>
      </div>
    </form>
  </div>
</div>
