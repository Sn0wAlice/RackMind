<% if (flash.success && flash.success.length) { %>
  <div class="alert alert-success fade-up">
    <i class="fa-solid fa-circle-check"></i>
    <span><%= flash.success[0] %></span>
    <button class="alert-close" aria-label="Dismiss"><i class="fa-solid fa-xmark"></i></button>
  </div>
<% } %>
<% if (flash.error && flash.error.length) { %>
  <div class="alert alert-error fade-up">
    <i class="fa-solid fa-circle-exclamation"></i>
    <span><%= flash.error[0] %></span>
    <button class="alert-close" aria-label="Dismiss"><i class="fa-solid fa-xmark"></i></button>
  </div>
<% } %>
<% if (flash.info && flash.info.length) { %>
  <div class="alert alert-info fade-up">
    <i class="fa-solid fa-circle-info"></i>
    <span><%= flash.info[0] %></span>
    <button class="alert-close" aria-label="Dismiss"><i class="fa-solid fa-xmark"></i></button>
  </div>
<% } %>
